# Copy to .env for local or Docker dev:
#   cp .env.example .env

# Backend API (browser calls this URL — use localhost when backend is exposed on host)
VITE_API_BASE_URL=http://localhost:8000/api

# Google reCAPTCHA (optional for local dev)
# Test key (always passes on localhost):
# VITE_RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
VITE_RECAPTCHA_SITE_KEY=

# Docker file watching (Windows / some WSL bind mounts)
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true

FRONTEND_PORT=5173
